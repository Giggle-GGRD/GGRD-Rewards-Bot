# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here_from_botfather

# Bot username (without @) - REQUIRED for DM-only mode
BOT_USERNAME=your_bot_username

# Channel to verify membership
CHANNEL_ID=@GGRDofficial

# Group to verify membership
GROUP_ID=@GGRDchat

# Twitter account to verify
TWITTER_HANDLE=@GGRD_Official

# MongoDB
# Option A (recommended on VPS): self-hosted MongoDB (docker compose / local service)
# If you set MONGODB_URI, bot will use it. Otherwise it will build URI from MONGODB_HOST/PORT/USER/PASS.
MONGODB_DB=ggrd_bot
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_USER=ggrd_bot_admin
MONGODB_PASS=CHANGE_ME_STRONG_PASSWORD
MONGODB_AUTHSOURCE=admin

# Option B: managed MongoDB/Atlas (set full URI and remove MONGODB_USER/PASS if you want)
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?appName=Cluster0


# Admin ID for admin commands
ADMIN_ID=your_telegram_id

# Solana RPC URL (use a private RPC on VPS for reliability)
# Examples:
# - https://api.mainnet-beta.solana.com (public, rate-limited)
# - https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# - https://solana-mainnet.gateway.tatum.io/
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# GGRD Token Mint Address on Solana
GGRD_TOKEN_MINT=TR97dHmm8nXVndTcxew21138AchNgrk2BhEJGXMybdE

# USDC mint (Solana)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Program parameters (v1)
MIN_HOLD_GGRD=100
MIN_NET_BUY_USDC=5
HOLD_TIME_1_HOURS=24
HOLD_TIME_2_HOURS=72
MAX_VERIFIED_REFERRALS_PER_DAY=10
MAX_POINTS_PER_WALLET_PER_WEEK=2000

# Ops
HOLD_CHECK_INTERVAL_MINUTES=30
HOLD_CHECK_ENABLED=true
LOG_LEVEL=info

# If using docker-compose for MongoDB (recommended on VPS)
MONGO_ROOT_USER=root
MONGO_ROOT_PASS=CHANGE_ME_ROOT_PASSWORD
