# ╔══════════════════════════════════════════════════════════════╗
# ║  GGRD Rewards Bot — .env (SECRETS ONLY)                    ║
# ║                                                            ║
# ║  All public values (bot username, mint addresses, channel  ║
# ║  IDs, program params) are hardcoded in src/config.js.      ║
# ║  You only need to fill in the secrets below.               ║
# ╚══════════════════════════════════════════════════════════════╝

# ── REQUIRED ──────────────────────────────────

# Telegram bot token (from @BotFather)
BOT_TOKEN=

# MongoDB app-user password (for docker-compose self-hosted Mongo)
MONGODB_PASS=

# MongoDB root password (used by docker-compose on first init)
MONGO_ROOT_PASS=

# ── OPTIONAL (have working defaults in config.js) ────────────

# Private Solana RPC (default: Tatum public endpoint)
# Recommended: Helius, QuickNode, or Alchemy for production
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Override any public default if needed:
# BOT_USERNAME=GGRD_Rewards_Bot
# ADMIN_ID=6191344175
# CHANNEL_ID=@GGRDofficial
# GROUP_ID=@GGRDchat
# GGRD_TOKEN_MINT=TR97dHmm8nXVndTcxew21138AchNgrk2BhEJGXMybdE
# USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# MONGODB_HOST=127.0.0.1
# MONGODB_PORT=27017
# MONGODB_DB=ggrd_bot
# MONGODB_USER=ggrd_bot_admin
# MONGODB_AUTHSOURCE=admin
# MONGO_ROOT_USER=root

# Override program parameters:
# MIN_HOLD_GGRD=100
# MIN_NET_BUY_USDC=5
# HOLD_TIME_1_HOURS=24
# HOLD_TIME_2_HOURS=72
# MAX_VERIFIED_REFERRALS_PER_DAY=10
# MAX_POINTS_PER_WALLET_PER_WEEK=2000
# HOLD_CHECK_INTERVAL_MINUTES=30
# HOLD_CHECK_ENABLED=true
# LOG_LEVEL=info
